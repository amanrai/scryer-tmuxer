# syntax=docker/dockerfile:1
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Layer 1: system packages
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /ui

# Layer 2: Python deps — rebuild only if this list changes
RUN --mount=type=cache,target=/root/.cache/pip \
    pip3 install fastapi uvicorn python-dotenv aiofiles itsdangerous python-multipart

# Layer 3: application code — rebuilds on every code change
COPY ui_server.py .
COPY sample_ui/ sample_ui/

EXPOSE 5679

CMD ["python3", "ui_server.py"]
